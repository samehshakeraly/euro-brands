// Euro Brands — Prisma Schema
// نظام إدارة المخزون والمبيعات

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // عند استخدام Vercel Postgres مع Migrate، فعّل السطر التالي:
  // directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------
//  Enums
// ----------------------------------------------------

enum Category {
  CLOTHES // ملابس
  SHOES // أحذية
  PERFUMES // عطور
  PANTS // بناطيل
}

enum Branch {
  HADAYEK // حدائق المعادي
  ZAHRAA // زهراء المعادي
}

enum DiscountType {
  PERCENTAGE // نسبة مئوية %
  FIXED // مبلغ ثابت
}

enum PaymentMethod {
  CASH // كاش
  VISA // فيزا
  TRANSFER // تحويل
}

enum SaleStatus {
  COMPLETED // مكتملة
  CANCELLED // ملغية
}

enum DeliveryMethod {
  CUSTOM // عامل خاص
  BOSTA
}

enum OrderSource {
  PHONE // تليفون
  FACEBOOK // فيسبوك
  INSTAGRAM // انستجرام
  WHATSAPP // واتساب
  MESSENGER // ماسنجر
}

enum DeliveryStatus {
  NEW // جديد
  PREPARING // قيد التجهيز
  READY // جاهز للشحن
  OUT_FOR_DELIVERY // خرج للتوصيل
  DELIVERED // تم التوصيل
  RETURNED // مرتجع
}

// ----------------------------------------------------
//  Models
// ----------------------------------------------------

model Product {
  id          String   @id @default(cuid())
  name        String
  brand       String
  category    Category
  description String?
  sku         String? // (مهجور) كان كود المنتج — الآن لكل صنف SKU خاص به
  barcode     String? // الباركود (اختياري)
  images      String[] @default([]) // حتى 3 صور

  productTypeId String?
  productType   ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)

  variants  ProductVariant[]
  saleItems SaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([brand])
  @@index([productTypeId])
}

// سجل البراندات لكل فئة (لقوائم الاختيار والفلاتر)
model Brand {
  id        String   @id @default(cuid())
  name      String
  category  Category
  createdAt DateTime @default(now())

  @@unique([name, category])
  @@index([category])
}

// أنواع المنتجات لكل فئة (مثلاً: تيشيرت/قميص داخل «ملابس»، حذاء رياضي/كلاسيك داخل «أحذية»)
// الـ code يُستخدم كبادئة لتوليد SKU التلقائي لكل صنف.
model ProductType {
  id        String   @id @default(cuid())
  name      String
  code      String // بادئة قصيرة (TSH, SNK, ...) تظهر في الـ SKU
  category  Category
  createdAt DateTime @default(now())

  products Product[]

  @@unique([name, category])
  @@index([category])
}

model ProductVariant {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  size        String // XS S M L XL 2XL 3XL 4XL 5XL أو مقاسات أرقام للأحذية
  color       String? // لون الصنف (اختياري)
  quantity    Int    @default(0)
  minQuantity Int    @default(5) // الحد الأدنى للتنبيه بقلة المخزون
  branch      Branch
  price       Float // سعر البيع لكل صنف بالجنيه المصري
  sku         String? @unique // كود الصنف (يولَّد تلقائياً أو يُدخَل يدوياً)
  skuManual   Boolean @default(false) // علامة أن المستخدم عدّل الكود يدوياً (لا يُعاد توليده)

  saleItems SaleItem[]

  @@unique([productId, size, branch, color])
  @@index([productId])
  @@index([branch])
}

model Sale {
  id         String  @id @default(cuid())
  saleNumber Int     @unique // رقم فاتورة تصاعدي عام
  branch     Branch

  totalAmount   Float // الإجمالي قبل الخصم
  discountType  DiscountType?
  discountValue Float         @default(0)
  finalAmount   Float // الصافي بعد الخصم

  customerName  String?
  customerPhone String?
  customerNotes String?

  paymentMethod   PaymentMethod @default(CASH)
  transferMethod  String? // فودافون كاش / انستا باي (عند التحويل)
  invoiceNotes    String? // ملاحظات على الفاتورة (مستقلة عن ملاحظات العميل)
  paidAmount      Float         @default(0) // المبلغ المدفوع
  remainingAmount Float         @default(0) // المبلغ المتبقي

  status             SaleStatus @default(COMPLETED)
  cancellationReason String? // سبب الإلغاء

  isDelivery       Boolean         @default(false)
  orderSource      OrderSource? // مصدر الطلب
  deliveryMethod   DeliveryMethod?
  deliveryAddress  String?
  addressNotes     String?
  trackingNumber   String? // رقم تتبع شركة الشحن (Bosta)
  deliveryStatus   DeliveryStatus?

  items SaleItem[]

  createdAt DateTime @default(now())

  @@index([branch])
  @@index([createdAt])
  @@index([status])
  @@index([isDelivery])
  @@index([deliveryStatus])
}

model SaleItem {
  id     String @id @default(cuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity  Int
  unitPrice Float
  subtotal  Float

  @@index([saleId])
  @@index([productId])
}
