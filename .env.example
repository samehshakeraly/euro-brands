# ====================================================
#  Euro Brands — متغيرات البيئة
# ====================================================

# --- وضع المعاينة (بيانات تجريبية بدون قاعدة بيانات) ---
# (المتصفح) استبدال كل طلبات الـ API ببيانات تجريبية مباشرة — لا يحتاج خادماً ولا DB.
#   1/true = تفعيل، 0/false = الـ API الحقيقي، غير محدد = مفعّل تلقائياً في التطوير فقط.
# NEXT_PUBLIC_MOCK="1"
#
# (الخادم) طبقة احتياطية: مسارات الـ API تُرجع بيانات تجريبية عند غياب DATABASE_URL،
#   أو بفرضها هنا:
# MOCK_DATA="1"

# قاعدة بيانات PostgreSQL (Vercel Postgres أو أي مزود آخر)
# مثال محلي: postgresql://postgres:postgres@localhost:5432/euro_brands
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# للاتصال المباشر عند استخدام Prisma Migrate مع Vercel Postgres (اختياري)
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Vercel Blob — لرفع صور المنتجات
# احصل عليه من: Vercel Dashboard > Storage > Blob > .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# Google Gemini — لتحليلات صفحة "الذكاء"
# احصل على مفتاح من: https://aistudio.google.com/app/apikey
# عند غيابه (أو عند فشل الطلب/نفاد الحصة) يتم الرجوع تلقائياً إلى تحليلات مبنية على قواعد.
GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# اختياري: اسم نموذج Flash (الافتراضي gemini-2.0-flash). ملاحظة: gemini-1.5-flash موقوف.
# GEMINI_MODEL="gemini-2.0-flash"

# المنطقة الزمنية — لضبط حساب "مبيعات اليوم" والتجميع اليومي بتوقيت القاهرة
TZ="Africa/Cairo"
