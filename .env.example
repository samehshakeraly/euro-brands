# ====================================================
#  Euro Brands — متغيرات البيئة
# ====================================================

# --- وضع المعاينة (بيانات تجريبية بدون قاعدة بيانات) ---
# إذا تركت DATABASE_URL فارغاً/غير معرّف، يعمل التطبيق تلقائياً ببيانات تجريبية
# في الذاكرة لمعاينة كامل الواجهة. لفرض هذا الوضع حتى مع وجود قاعدة بيانات:
# MOCK_DATA="1"

# قاعدة بيانات PostgreSQL (Vercel Postgres أو أي مزود آخر)
# مثال محلي: postgresql://postgres:postgres@localhost:5432/euro_brands
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# للاتصال المباشر عند استخدام Prisma Migrate مع Vercel Postgres (اختياري)
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Vercel Blob — لرفع صور المنتجات
# احصل عليه من: Vercel Dashboard > Storage > Blob > .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# المنطقة الزمنية — لضبط حساب "مبيعات اليوم" والتجميع اليومي بتوقيت القاهرة
TZ="Africa/Cairo"
